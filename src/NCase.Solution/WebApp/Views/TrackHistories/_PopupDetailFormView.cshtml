     </div>
    <!--end window body -->
</div>
<div id="windowfooter" style="padding:5px;">&nbsp;</div>
<!-- 弹出窗体form表单 -->
<!-- 弹出编辑对话框 -->

<!--begin popup detailview javascript block -->
<script type="text/javascript">
    //判断新增编辑状态
    var MODELSTATE = 'Added';
    var trackhistoryid = null;
    function opentrackhistorydetailwindow(data,state) {
         MODELSTATE = state;
         inittrackhistorydetailview();
         trackhistoryid = (data.Id || 0);
         $('#trackhistorydetailwindow').window('open');
         $('#trackhistory_form').form('reset');
         $('#trackhistory_form').form('load', data);
             }
  //删除当前记录
  function deletetrackhistoryitem() {
    $.messager.confirm('确认', '你确定要删除该记录?', result => {
      if (result) {
        const url = `/TrackHistories/Delete/${trackhistoryid}`;
        $.get(url).done(res => {
          if (res.success) {
            toastr.success("删除成功");
            $dg.datagrid('reload');
            $('#trackhistorydetailwindow').window('close');
          } else {
            $.messager.alert('错误', res.err, 'error');
          }
        });
      }
    });
  }
    //async 保存数据
    async function savetrackhistoryitem() { 
      const $trackhistoryform = $('#trackhistory_form');
      if ($trackhistoryform.form('enableValidation').form('validate')) {
            let trackhistory = $trackhistoryform.serializeJSON();
            let url = '/TrackHistories/Edit';
            //判断是新增或是修改方法
            if (MODELSTATE === 'Added') {
                url = '/TrackHistories/Create';
            }
            var token = $('input[name="__RequestVerificationToken"]', $trackhistoryform).val();
            $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval:200});
            $.ajax({
                    type: "POST",
                    url: url,
                    data: {
                        __RequestVerificationToken: token,
                        trackhistory:trackhistory
                    },
                    dataType: 'json',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8'
                })
                .done(response => {
                    $.messager.progress('close');
                    if (response.success) {
                        hook = false;
                        $trackhistoryform.form('disableValidation');
                        $dg.datagrid('reload');
                        $('#trackhistorydetailwindow').window("close");
                        toastr.success("保存成功");  
                    } else {
                        $.messager.alert("错误",   response.err, "error");
                    }
                    })
                .fail((jqXHR, textStatus, errorThrown) => {
                       $.messager.progress('close');
                       $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
                    });
        }
    }
    //关闭窗口
    function closetrackhistorydetailwindow() {
        $('#trackhistorydetailwindow').window('close');
    }
    //todo
    function todo() {
         console.log('todo.....');
    }
     //判断是否有没有保存的记录
     function trackhistoryhasmodified() {
            return hook;

     }


function inittrackhistorydetailview() {
  //判断是否显示功能按钮
  if (MODELSTATE === 'Added') {
    $('#deleteitem-btn-group').hide();
  } else {
    $('#deleteitem-btn-group').show();
  }
 
//回车光标移动到下个输入控件
    //如果是枚举类型需要把numberbox改成combobox
    //限期
	$('#Expires').numberbox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
    //如果是枚举类型需要把numberbox改成combobox
    //实际用时
	$('#Elapsed').numberbox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
    //日期类型 开始时间
	$('#BeginDate').datebox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
    //日期类型 完成时间
	$('#CompletedDate').datebox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
    //日期类型 届满日期
	$('#DoDate').datebox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
    //日期类型 创建时间
	$('#Created').datebox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
}
</script>

