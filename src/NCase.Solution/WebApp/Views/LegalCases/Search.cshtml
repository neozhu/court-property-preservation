    //计算剩余天数
    function remdays(date1, days) {
      var date2 = new Date();
      var date1 = moment(date1).add(days, 'day')
      // The number of milliseconds in one day
      const ONE_DAY = 1000 * 60 * 60 * 24;

      // Calculate the difference in milliseconds
      const differenceMs = Math.abs(date1 - date2);
      if (differenceMs >= 0) {
        // Convert back to days and return
        return {days:Math.round(differenceMs / ONE_DAY),text:`剩余${Math.round(differenceMs / ONE_DAY)}天 ` };
      } else {
        return { days: Math.round(differenceMs / ONE_DAY), text: `超过${Math.round(differenceMs / ONE_DAY)}天 ` };
      }

    }

