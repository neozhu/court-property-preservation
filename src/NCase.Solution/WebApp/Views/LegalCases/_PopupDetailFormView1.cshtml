            <input id="@Html.IdFor(model => model.PreUnderlyingAsset)"
                   name="@Html.NameFor(model => model.PreUnderlyingAsset)"
                   value="@Html.ValueFor(model => model.PreUnderlyingAsset)"
                   tabindex="17"
                   class="easyui-numberspinner"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.PreUnderlyingAsset)',
								 required:true, precision:2,formatter:numberformatter

                                 " />

          </div>
        </div>
        <!--立案部门-->
