        </div>
        <!--应结案日期-->
        <div class="form-group  col-md-6">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.PreCloseDate)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.PreCloseDate)"
                   name="@Html.NameFor(model => model.PreCloseDate)"
                   value="@Html.ValueFor(model => model.PreCloseDate)"
                   tabindex="19"
                   class="easyui-datebox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.PreCloseDate)',
								 required:false,readonly:true,
								 formatter:dateformatter" />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
