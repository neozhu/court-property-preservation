                   value="@Html.ValueFor(model => model.Status)"
                   tabindex="3" required
                   class="easyui-combobox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Status)',
								 required:true,readonly:true,data:statusdatasource,editable:false,validType: 'length[0,10]'
                                 " />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
        <!--限期-->
