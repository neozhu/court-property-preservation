                   tabindex="11"
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.ToUser)',
								 required:false,
                                 validType: 'length[0,20]'
                                 " />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
        <!--书记员-->
        <div class="form-group  col-md-6" style="display:none">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.Recorder)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.Recorder)"
                   name="@Html.NameFor(model => model.Recorder)"
                   value="@Html.ValueFor(model => model.Recorder)"
                   tabindex="12"
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Recorder)',
								 required:false,
                                 validType: 'length[0,20]'
                                 " />
          </div>
        </div>
        <!--立案审查人-->
        <div class="form-group  col-md-6" style="display:none">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.Examiner)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.Examiner)"
                   name="@Html.NameFor(model => model.Examiner)"
                   value="@Html.ValueFor(model => model.Examiner)"
                   tabindex="13"
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Examiner)',
								 required:false,
                                 validType: 'length[0,20]'
                                 " />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
        <!--原案（执行）案号-->
        <div class="form-group  col-md-6">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.OriginCaseId)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.OriginCaseId)"
                   name="@Html.NameFor(model => model.OriginCaseId)"
                   value="@Html.ValueFor(model => model.OriginCaseId)"
                   tabindex="14"
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.OriginCaseId)',
								 required:false, validType: 'length[0,256]'
                                 " />
          </div>
        </div>
        <!--收案日期-->
        <div class="form-group  col-md-6">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.ReceiveDate)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.ReceiveDate)"
                   name="@Html.NameFor(model => model.ReceiveDate)"
                   value="@Html.ValueFor(model => model.ReceiveDate)"
                   tabindex="15"
                   class="easyui-datebox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.ReceiveDate)',
								 required:false,
								 formatter:dateformatter" />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
        <!--立案日期-->
        <div class="form-group  col-md-6">
          <label class="col-md-4 control-label"><span class="required">@Html.DisplayNameFor(model => model.RegisterDate)</span></label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.RegisterDate)"
                   name="@Html.NameFor(model => model.RegisterDate)"
                   value="@Html.ValueFor(model => model.RegisterDate)"
                   tabindex="16" required
                   class="easyui-datebox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.RegisterDate)',
								 required:true, formatter:dateformatter,
                   onChange:function(v) {
                    var dt=$('#legalcase_form #RegisterDate').datebox('getValue');
                    var num=$('#legalcase_form #Expires').numberspinner('getValue');
                    dt=moment(dt).add('days', num).format('YYYY-MM-DD');
                    $('#legalcase_form #PreCloseDate').datebox('setValue',dt);
                   }," />
          </div>
        </div>

        <!--end row-->
        <!-- begin row -->
        <!--分案时间-->
        <div class="form-group  col-md-6" style="display:none">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.AllocateDate)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.AllocateDate)"
                   name="@Html.NameFor(model => model.AllocateDate)"
                   value="@Html.ValueFor(model => model.AllocateDate)"
                   tabindex="18"
