                   value="@Html.ValueFor(model => model.Expires)"
                   tabindex="4"
                   class="easyui-numberspinner"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Expires)',
                   onChange:function(v) {
                    var dt=$('#legalcase_form #RegisterDate').datebox('getValue');
                    dt=moment(dt).add('days', v).format('YYYY-MM-DD');
                    $('#legalcase_form #PreCloseDate').datebox('setValue',dt);
                   },
                   required:true" />
          </div>
        </div>
        <!--申请执行标的-->
