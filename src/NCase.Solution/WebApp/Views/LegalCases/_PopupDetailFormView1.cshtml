<!--begin popup detailview javascript block -->
<script type="text/javascript">
  //判断新增编辑状态
  var MODELSTATE = 'Added';
  var legalcaseid = null;
  function openlegalcasedetailwindow(data, state) {
    MODELSTATE = state;
    initlegalcasedetailview();
    legalcaseid = (data.Id || 0);
    $('#legalcase_form #yeartxt').textbox('setValue', `（${new Date().getFullYear()}）`);
    $('#legalcasedetailwindow').window('open');
    $('#legalcase_form').form('reset');
    $('#legalcase_form').form('load', data);

    if (MODELSTATE != 'Added') {
      $('#legalcase_form #yeartxt').textbox('setValue', `（${new Date().getFullYear()}）`);
      $('#legalcase_form #seqnotxt').numberbox('setValue', 1);
      $('#legalcase_form #Category').combobox('setValue', '保变');
    }
    var url = `/Courts/GetComboData?name=${data.Org}`;
    
    $('#legalcase_form #Court').combobox('reload', url);
    $('#legalcase_form #FromDepartment').combobox('reload', url);
  }
  //删除当前记录
  function deletelegalcaseitem() {
    $.messager.confirm('确认', '你确定要删除该记录?', result => {
      if (result) {
        const url = `/LegalCases/Delete/${legalcaseid}`;
        $.get(url).done(res => {
          if (res.success) {
            toastr.success("删除成功");
            $dg.datagrid('reload');
            $('#legalcasedetailwindow').window('close');
          } else {
            $.messager.alert('错误', res.err, 'error');
          }
        });
      }
    });
  }
  //验证案号是否存在
  async function validateCaseId() {
    if (MODELSTATE === 'Added') {
      var year = $('#legalcase_form #yeartxt').textbox('getValue');
      var serial = $('#legalcase_form #serialtxt').combobox('getValue');
      var category = $('#legalcase_form #Category').combobox('getValue');
      var num = $('#legalcase_form #seqnotxt').numberbox('getValue');
      if (num == '' || num == null || num == 0) {
        $.messager.alert(
          {
            title: '提示',
            msg: '请输入有效的案件序号!',
            fn: function () {
              setTimeout(() => {
                $('#legalcase_form #seqnotxt').numberbox('textbox').focus();
              }, 300)
            }
          }
        );

        return false;
      }
      const url = `/LegalCases/validateCaseId?caseid=${year + serial + category + num}号`;
      console.log(url);
      const exist = await $.get(url);
      if (exist) {
        $.messager.alert({
          title: '提示',
          msg: `该案号 [${year + serial + category + num}号] 已经存在,请重新修改后再试`,
          fn: function () {
            setTimeout(() => {
              $('#legalcase_form #seqnotxt').numberbox('textbox').focus();
            }, 300)
          }
        });


        return false;
      }
      else {
        return true;
      }
    } else {
      return true;
    }

  }

  async function setCaseId() {
    if (MODELSTATE === 'Added') {
      var year = $('#legalcase_form #yeartxt').textbox('getValue');
      var serial = $('#legalcase_form #serialtxt').combobox('getValue');
      var category = $('#legalcase_form #Category').combobox('getValue');
      if (year && serial && category) {
        const url = `/LegalCases/GetCaseExpires?year=${year}&serial=${serial}&category=${category}`;
        var result = await $.get(url);
        //$('#legalcase_form #CaseId').textbox('setValue', result.caseid);
        $('#legalcase_form #seqnotxt').textbox('setValue', result.seqno);
        $('#legalcase_form #Expires').numberspinner('setValue', result.expires);
      }
    }
  }
  //async 保存数据
  async function savelegalcaseitem() {
    var year = $('#legalcase_form #yeartxt').textbox('getValue');
    var serial = $('#legalcase_form #serialtxt').combobox('getValue');
    var category = $('#legalcase_form #Category').combobox('getValue');
    var num = $('#legalcase_form #seqnotxt').numberbox('getValue');
    const $legalcaseform = $('#legalcase_form');

    if ($legalcaseform.form('enableValidation').form('validate') && await validateCaseId()) {
      let legalcase = $legalcaseform.serializeJSON();
      

      legalcase.SerialNumber = $('#serialtxt').combobox('getValue');
      
      let url = '/LegalCases/Edit';
      //判断是新增或是修改方法
      if (MODELSTATE === 'Added') {
        url = '/LegalCases/Register';
        legalcase.CaseId = `${year + serial + category + num} 号`;
      }
      var token = $('input[name="__RequestVerificationToken"]', $legalcaseform).val();
      $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval: 200 });
      $.ajax({
        type: "POST",
        url: url,
        data: {
          __RequestVerificationToken: token,
          legalcase: legalcase
        },
        dataType: 'json',
        contentType: 'application/x-www-form-urlencoded; charset=utf-8'
      })
        .done(response => {
          $.messager.progress('close');
          if (response.success) {
            hook = false;
            $legalcaseform.form('disableValidation');
            $dg.datagrid('reload');
            $('#legalcasedetailwindow').window("close");
            toastr.success("保存成功");
          } else {
            $.messager.alert("错误", response.err, "error");
          }
        })
        .fail((jqXHR, textStatus, errorThrown) => {
          $.messager.progress('close');
          $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
        });
    }
  }
  //关闭窗口
  function closelegalcasedetailwindow() {
    $('#legalcasedetailwindow').window('close');
  }
  //todo
  function todoCompete() {
    const url = `/LegalCases/DoComplete/${legalcaseid}`;
    $.messager.progress({ title: '请等待', msg: '正在生成立案审批表...', interval: 200 });
    $.get(url).done(response => {
      $.messager.progress('close');
      if (response.success) {
        hook = false;
        $dg.datagrid('reload');
        $('#legalcasedetailwindow').window("close");
        toastr.success("完成");
        $.get(`/LegalCases/ExportWord/${legalcaseid}`).done(res => {
          console.log(res);
          if (res.success) {
            const url = `/FileUpload/Download?file=${res.filename}`;
            $.fileDownload(url)
              .done(() => {
                //console.log('file download a success!');
                toastr.success('下载完成!');
              })
              .fail(() => {
                $.messager.alert('下载失败', '没有下载到文件!', 'error');
              });
          } else {
            $.messager.alert("错误", res.err, "error");
          }
        })
      } else {
        $.messager.alert("错误", response.err, "error");
      }
    });
  }
  //判断是否有没有保存的记录
  function legalcasehasmodified() {
    return hook;

  }


  function initlegalcasedetailview() {
    //判断是否显示功能按钮
    if (MODELSTATE === 'Added') {
      $('#complete-btn-group').hide();
      $('#caseidinput').show();
      $('#caseiddiv').hide();
    } else {
      $('#complete-btn-group').show();
      $('#caseidinput').hide();
      $('#caseiddiv').show();
   
    }

     
  }
</script>

