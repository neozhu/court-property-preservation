﻿@model WebApp.Models.LegalCase
<!-- 弹出窗体form表单 -->
<div id="legalcasedetailwindow" hidden="hidden" class="easyui-window"
     title="立案登记"
     data-options="modal:true,
                    closed:true,
                    minimizable:false,
                    collapsible:false,
                    maximized:false,
                    iconCls:'icon-more',
                    footer:'#windowfooter',
                    closeDuration:200,
                    closeAnimation:'slide',
                    openDuration:300,
                    openAnimation:'slide',
                    onBeforeClose:function(){
                      var that = $(this);
                      if(legalcasehasmodified()){
                        $.messager.confirm('确认','你确定要放弃保存修改的记录?',function(r){
                        if (r){
                          var opts = that.panel('options');
                          var onBeforeClose = opts.onBeforeClose;
                          opts.onBeforeClose = function(){};
                          that.panel('close');
                          opts.onBeforeClose = onBeforeClose;
                          hook = false;
                        }
                        });
                        return false;
                      }
                    },
                    onOpen:function(){
                       $(this).window('vcenter');
                       $(this).window('hcenter');
                    },
                    onRestore:function(){
                    },
                    onMaximize:function(){
                    }
                    " style="width:1080px;height:420px">
  <!-- begin toolbar -->
  <div class="window-body-toolbar">
    <div class="row">
      <div class="col-sm-8">
        <div class="btn-group btn-group-sm">
          <button name="saveitembutton" onclick="savelegalcaseitem()" class="btn btn-default">
            <i class="fa fa-floppy-o"></i> @Html.L("Save")
          </button>
        </div>
        <div class="btn-group btn-group-sm" style="display:none" id="deleteitem-btn-group">
          <button onclick="deletelegalcaseitem()" class="btn btn-danger">
            <i class="fa fa-trash-o"></i> @Html.L("Delete")
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="complete-btn-group" style="display:none">
          <button onclick="todoCompete()" class="btn btn-default btn-success">
            <i class="fa fa-check-square-o"></i> 移交案件
          </button>
        </div>
      </div>
      <div class="col-sm-4 text-align-right">
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn   btn-success" onclick="closelegalcasedetailwindow()">
            <i class="fa fa-chevron-left"></i>
            @Html.L("Close")
          </button>
        </div>
      </div>
    </div>
  </div>
  <!-- end toolbar -->
  <!-- begin window body -->
  <div class="widget-body">
    <form id="legalcase_form"
          class="easyui-form form-horizontal padding-10"
          method="post"
          data-options="novalidate:true,
                            onChange: function(target){
                              hook = true;
                              $('button[name*=\'saveitembutton\']').prop('disabled', false);
                             },
                             onLoadSuccess:function(data){
                               hook = false;
                               $('button[name*=\'saveitembutton\']').prop('disabled', true);
                             }">
      @Html.AntiForgeryToken()
      <!--Primary Key-->
      @Html.HiddenFor(model => model.Id)
      <!--节点-->
      @Html.HiddenFor(model => model.Node)

      <fieldset>
        <!-- begin row -->
        <!--档案编号-->
        <div class="form-group  col-md-6" id="caseiddiv">
          <label class="col-md-4 control-label"><span class="required">@Html.DisplayNameFor(model => model.CaseId)</span></label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.CaseId)"
                   name="@Html.NameFor(model => model.CaseId)"
                   value="@Html.ValueFor(model => model.CaseId)"
                   tabindex="0" required
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.CaseId)',
								 required:true,readonly:true,
                                 validType: 'length[0,128]'
                                 " />
          </div>
        </div>
        <div class="form-group  col-md-6" id="caseidinput">
          <label class="col-md-4 control-label"><span class="required">@Html.DisplayNameFor(model => model.CaseId)</span></label>
          <div class="col-md-8">
            <input id="yeartxt"
                   name="yeartxt"
                   value=""
                   tabindex="0" required
                   class="easyui-textbox"
                   style="width:70px"
                   type="text"
                   data-options="prompt:'（年份）', readonly:true,
								 required:true,validType: 'length[0,6]',
                   onChange:function(){ setCaseId() }
                                 " />
            <input id="serialtxt"
                   name="serialtxt"
                   value="粤0605"
                   tabindex="0" required
                   class="easyui-combobox"
                   style="width:90px"
                   type="text"
                   data-options="prompt:'冠字号',data:serialdatasource,
								 required:true,validType: 'length[0,5]',panelHeight:'auto',
                   onChange:function(){ setCaseId() }
                                 " />
            <input id="@Html.IdFor(model => model.Category)"
                   name="@Html.NameFor(model => model.Category)"
                   value="@Html.ValueFor(model => model.Category)"
                   tabindex="2" required
                   class="easyui-combobox"
                   style="width:70px"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Category)',
								 required:true,data:categorydatasource,editable:false,panelHeight:'auto',
                   onChange:function(){ setCaseId() },
                                 validType: 'length[0,20]'
                                 " />
            <input id="seqnotxt"
                   name="seqnotxt"
                   value=""
                   tabindex="0" required
                   class="easyui-numberbox"
                   style="width:40px"
                   type="text"
                   data-options="prompt:'序号',readonly:false,
								   required: false,min:1,max:9999,
                   onChange:function() {
                    //validateCaseId();
                   }
                                 " />号
          </div>
        </div>

        <!--案件名称-->
        <div class="form-group  col-md-6" style="display:none">
          <label class="col-md-4 control-label">@Html.DisplayNameFor(model => model.Project)</label>
          <div class="col-md-8">
            <input id="@Html.IdFor(model => model.Project)"
                   name="@Html.NameFor(model => model.Project)"
                   value="@Html.ValueFor(model => model.Project)"
                   tabindex="1"
                   class="easyui-textbox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.Project)',
								 required:false,       validType: 'length[0,256]'
                                 " />
          </div>
        </div>
        <!--end row-->
        <!-- begin row -->
        <!--状态-->
        <div class="form-group  col-md-6">
          <label class="col-md-4 control-label"><span class="required">@Html.DisplayNameFor(model => model.Status)</span></label>
          <div class="col-md-8">
