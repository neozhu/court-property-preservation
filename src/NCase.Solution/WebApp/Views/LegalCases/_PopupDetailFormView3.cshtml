﻿@model WebApp.Models.LegalCase
<!-- 弹出窗体form表单 -->
<div id="legalcasedetailwindow" hidden="hidden" class="easyui-window"
     title="执行完成"
     data-options="modal:true,
                    closed:true,
                    minimizable:false,
                    collapsible:false,
                    maximized:false,
                    iconCls:'icon-more',
                    footer:'#windowfooter',
                    closeDuration:200,
                    closeAnimation:'slide',
                    openDuration:300,
                    openAnimation:'slide',
                    onBeforeClose:function(){
              
                      
                    },
                    onOpen:function(){
                       $(this).window('vcenter');
                       $(this).window('hcenter');
                    },
                    onRestore:function(){
                    },
                    onMaximize:function(){
                    }
                    " style="width:1020px;height:650px">
  <!-- begin toolbar -->
  <div class="window-body-toolbar">
    <div class="row">
      <div class="col-sm-8">
        <div class="btn-group btn-group-sm" id="saveitembutton">
          <button name="saveitembutton" onclick="savelegalcaseitem(3)" class="btn btn-default btn-success">
            <i class="fa fa-gavel"></i> 执行完成
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="managerbtn">
          <button name="managerbtn" onclick="savelegalcaseitem(4)" class="btn btn-default btn-success">
            <i class="fa fa-check-square-o"></i> 审批确认
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="closebtn">
          <button name="closebtn" onclick="savelegalcaseitem(5)" class="btn btn-default btn-success">
            <i class="fa fa-envelope-o"></i> 结案
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="extractionbtn">
          <button name="extractionbtn" onclick="savelegalcaseitem(6)" class="btn btn-default btn-success">
            <i class="fa fa-search"></i> 调取
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="archivebtn">
          <button name="extractionbtn" onclick="savelegalcaseitem(7)" class="btn btn-default btn-success">
            <i class="fa fa-archive"></i> 归档
          </button>
        </div>
        <div class="btn-group btn-group-sm" id="complete-btn-group">
          <button onclick="gobacktask()" class="btn btn-default btn-danger">
            <i class="fa fa-undo"></i> 退回
          </button>
        </div>
      </div>
      <div class="col-sm-4 text-align-right">
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn   btn-success" onclick="closelegalcasedetailwindow()">
            <i class="fa fa-chevron-left"></i>
            @Html.L("Close")
          </button>
        </div>
      </div>
    </div>
  </div>
  <!-- end toolbar -->
  <!-- begin window body -->
  <div class="widget-body">
    <form id="legalcase_form"
          class="easyui-form form-horizontal padding-10"
          method="post"
          data-options="novalidate:true,
                            onChange: function(target){
                              hook = true;
                            },
                             onLoadSuccess:function(data){
                               hook = false;
                               
                             }">
      @Html.AntiForgeryToken()
      <!--Primary Key-->
      @Html.HiddenFor(model => model.Id)
      <!--节点-->
      @Html.HiddenFor(model => model.Node)
      <fieldset id="step5">
        <legend>结案信息</legend>
        <!--结案方式-->
        <div class="form-group  col-md-6">
          <label class="col-md-3 control-label">@Html.DisplayNameFor(model => model.CloseType)</label>
          <div class="col-md-9">
            <input id="@Html.IdFor(model => model.CloseType)"
                   name="@Html.NameFor(model => model.CloseType)"
                   value="@Html.ValueFor(model => model.CloseType)"
                   tabindex="21"
                   class="easyui-combobox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.CloseType)',
								 required:false,validType: 'length[0,50]',data:closetypedatasource
                                 " />
          </div>
        </div>
        <!--结案标的-->
        <div class="form-group  col-md-6">
          <label class="col-md-3 control-label"><span class="required">@Html.DisplayNameFor(model => model.UnderlyingAsset)</span></label>
          <div class="col-md-9">
            <input id="@Html.IdFor(model => model.UnderlyingAsset)"
                   name="@Html.NameFor(model => model.UnderlyingAsset)"
                   value="@Html.ValueFor(model => model.UnderlyingAsset)"
                   tabindex="22"
                   class="easyui-numberspinner"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.UnderlyingAsset)',
								 required:false,precision:2,formatter:numberformatter " />

          </div>
        </div>
        <!--结案日期-->
        <div class="form-group  col-md-6">
          <label class="col-md-3 control-label">@Html.DisplayNameFor(model => model.ClosedDate)</label>
          <div class="col-md-9">
            <input id="@Html.IdFor(model => model.ClosedDate)"
                   name="@Html.NameFor(model => model.ClosedDate)"
                   value="@Html.ValueFor(model => model.ClosedDate)"
                   tabindex="20"
                   class="easyui-datebox"
                   style="width:100%"
                   type="text"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.ClosedDate)',
								 required:false,
								 formatter:dateformatter" />
          </div>
        </div>

        <!--end row-->
        <!-- begin row -->


      </fieldset>
      <fieldset id="step4">
        <legend>部门领导批示</legend>
