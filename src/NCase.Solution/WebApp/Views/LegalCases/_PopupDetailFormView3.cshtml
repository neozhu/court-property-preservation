<script type="text/javascript">
  //判断新增编辑状态
  var MODELSTATE = 'Added';
  var legalcaseid = null;

  function gobacktask() {
    const id = $('#legalcase_form #Id').val();
     $.get(`/LegalCases/GoBack/${id}`).done(res => {
        reload();
       $('#legalcasedetailwindow').window('close');
      })
  }
  function downloadfile(path) {
          //默认模板路径存放位置
          const url = `/FileUpload/Download?file=${path}`;
          $.fileDownload(url)
           .done(() => {
                    //console.log('file download a success!');
                    toastr.success('下载完成!');
                })
           .fail(() => {
               $.messager.alert('下载失败','没有找到文件!','error');
            });
       }
  function openlegalcasedetailwindow(data, state) {
    MODELSTATE = state;
    legalcaseid = (data.Id || 0);
    
    $('#legalcasedetailwindow').window('open');
    $('#legalcase_form').form('reset');
    $('#legalcase_form').form('load', data);
    var url = `/Courts/GetComboData?name=${data.Org}`;
    $('#legalcase_form #Court').combobox('reload', url);
    $('#legalcase_form #ToDepartment').combobox('reload', url);
   
    url = `/NodeConfigs/GetUsers?rolename=承办人`
    $('#legalcase_form #ToUser').combobox('reload', url);
    url = `/NodeConfigs/GetUsers?rolename=书记员`
    $('#legalcase_form #Recorder').combobox('reload', url);
    url = `/NodeConfigs/GetUsers?rolename=部门领导`
    $('#legalcase_form #Manager').combobox('reload', url);

    FilePond.registerPlugin(
      FilePondPluginFileValidateSize
    );
    FilePond.setOptions({
      instantUpload: true,
      labelIdle: '请上传相关材料  <span class="filepond--label-action"> 选择 </span>',
      server: {
        timeout: 7000,
        process: {
          url: '/LegalCases/UploadFile',
          method: 'POST',
          ondata: (formData) => {
            formData.append('CaseId', legalcaseid);
            return formData;
          },
          onerror: (response) => {
            console.log(response);
          },
          onload: (response) => {
            setTimeout(() => {
              loadAttachments()

            }, 500);
            return response;
          },
        },
        revert: '/LegalCases/Revert',
      },

    })
    const inputElement = document.querySelector('input[id="filepond"]');
    const pond = FilePond.create(inputElement);
    loadAttachments()
    setdisplaystep(data.Status);
  }

  //根据状态显示隐藏
  function setdisplaystep(status) {
    if (status == '执行') {
      $('#saveitembutton').show();
      $('#managerbtn').hide();
      $('#closebtn').hide();
      $('#extractionbtn').hide();
      $('#archivebtn').hide();
      $('#step5').hide();
      $('#step4').hide();
      $('#step3').show();
      $('#legalcase_form #ToManager').prop("checked", false);
      $('#legalcase_form #ToManager').prop("disabled", false);
    } else if (status == '审批') {
      $('#saveitembutton').hide();
      $('#managerbtn').show();
      $('#closebtn').hide();
      $('#extractionbtn').hide();
      $('#archivebtn').hide();
      $('#step5').hide();
      $('#step4').show();
      $('#step3').show();
      $('#legalcase_form #Opinion3').combobox('readonly', false);
      $('#legalcase_form #ToManager').prop("disabled", true);
      $('#legalcase_form #Manager').combobox('readonly', true);
      $('#legalcase_form #Opinion3').combobox('setValue','同意结案')
    } else if (status == '办结') {
      $('#saveitembutton').hide();
      $('#managerbtn').hide();
      $('#closebtn').show();
      $('#extractionbtn').hide();
      $('#archivebtn').hide();
      $('#step5').show();
      $('#step4').show();
      $('#step3').show();
      $('#legalcase_form #Opinion3').combobox('readonly');
      $('#legalcase_form #ClosedDate').datebox('setValue', moment().format('YYYY-MM-DD HH:mm:ss'));
      $('#legalcase_form #CloseType').combobox('setValue','正常结案')
    }
    else if (status == '调取') {
      $('#saveitembutton').hide();
      $('#managerbtn').hide();
      $('#closebtn').hide();
      $('#extractionbtn').hide();
      $('#archivebtn').show();
      $('#step5').show();
      $('#step4').show();
      $('#step3').show();
      $('#legalcase_form #Opinion3').combobox('readonly');
      $('#legalcase_form #ClosedDate').datebox('setValue', moment().format('YYYY-MM-DD HH:mm:ss'));
    }
    else {
      $('#saveitembutton').hide();
      $('#managerbtn').hide();
      $('#closebtn').hide();
      $('#extractionbtn').show();

       $('#step5').show();
      $('#step4').show();
      $('#step3').show();
    }

  }
  //获取附件
  function loadAttachments() {
    const caseid = $('#legalcase_form #CaseId').textbox('getValue');
    const url = `/Attachments/GetAttachments?caseid=${caseid}`;
    $.get(url).done(res => {
      console.log(res)
      if (res) {
        $('#attachmentsdiv').empty()
        res.forEach(item => {
          const html=`<div class="col-md-2">
              <div class="thumbnail">
                <img src="/Content/img/doc.jpg" alt="${item.DocId}">
                <div class="caption">
                  <p>${item.Type}</p>
                  <p style="text-overflow:ellipsis;white-space:nowrap;overflow:hidden;">${item.DocId}</p>
                  <p><a href="#" onclick="downloadfile('${item.Path}')" class="btn btn-sm btn-primary" role="button">下载</a> <a href="#" class="btn btn-sm btn-default" role="button">删除</a></p>
                </div>
              </div>
            </div>`
          $('#attachmentsdiv').append(html);
        })
      }
    })
  }
  
  //退回
  function goback() {
    if (legalcaseid) {
      hook = false;
      const url = `/LegalCases/BackStep2/${legalcaseid}`;
      $.get(url).done(res => {
        if (res.success) {
          toastr.success("已退回分案");
          $dg.datagrid('reload');
          $('#legalcasedetailwindow').window('close');
        } else {
          $.messager.alert('错误', res.err, 'error');
        }
      });

    }

  }
  //async 保存数据
  async function savelegalcaseitem(step) {

    const $legalcaseform = $('#legalcase_form');
    if ($legalcaseform.form('enableValidation').form('validate')) {
      let legalcase = $legalcaseform.serializeJSON();
      console.log(legalcase,step);
      debugger
      legalcase.FilingDate = moment().format('YYYY-MM-DD HH:mm:ss');
      legalcase.Proposer = '@Auth.GetFullName()';
      let url = '/LegalCases/ExecutionTask';
      if (legalcase.ToManager == 'true') {
        if (legalcase.Manager == '') {
          $.messager.alert('提示', '请选择部门领导');
          return;
        }
      }
      if (step == 4) {
        url = '/LegalCases/ManagerTask';
       
      } else if (step == 5) {
        url = '/LegalCases/CloseTask';
      } else if (step == 6) {
        url = '/LegalCases/ExtractionTask';
      } else if (step == 7) {
        url = '/LegalCases/ArchiveTask';
      }
      //判断是新增或是修改方法
      $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval: 200 });
      $.ajax({
        type: "POST",
        url: url,
        data: {
          legalcase: legalcase
        },
        dataType: 'json',
        contentType: 'application/x-www-form-urlencoded; charset=utf-8'
      })
        .done(response => {
          $.messager.progress('close');
          if (response.success) {
            hook = false;
            $legalcaseform.form('disableValidation');
            $dg.datagrid('reload');
            $('#legalcasedetailwindow').window("close");
            toastr.success("任务完成");
          } else {
            $.messager.alert("错误", response.err, "error");
          }
        })
        .fail((jqXHR, textStatus, errorThrown) => {
          $.messager.progress('close');
          $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
        });
    }
  }


  //关闭窗口
  function closelegalcasedetailwindow() {
    $('#legalcasedetailwindow').window('close');
  }
