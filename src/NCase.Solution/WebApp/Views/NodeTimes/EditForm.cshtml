﻿@model WebApp.Models.NodeTime
<!-- begin master section -->
<div  class="main-form">
<!--begin nodetime form  -->
<form id="nodetime_form" method="post" novalidate="novalidate" >
@Html.AntiForgeryToken()
   @Html.HiddenFor(x=>x.Id)
 <fieldset>
 <div class="form-group form-group-sm">
      <div class="row">

        <!--案件类型-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Category)</span> </label>
			@Html.EditorFor(x => x.Category, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Category) } })
      
         </div>

        <!--节点-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Node)</span> </label>
			@Html.EditorFor(x => x.Node, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Node) } })
      
         </div>

		<!--天数-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Days)</span> </label>
            @Html.EditorFor(x => x.Days, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Days) } })

        </div>
	    
   </div>
  </div>
</fieldset>
</form>
<!-- end nodetime form  -->
</div>

<!-- end master section -->
<!--========================================================================================-->

