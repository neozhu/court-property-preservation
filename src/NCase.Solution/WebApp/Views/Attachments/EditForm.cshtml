﻿@model WebApp.Models.Attachment
<!-- begin master section -->
<div  class="main-form">
<!--begin attachment form  -->
<form id="attachment_form" method="post" novalidate="novalidate" >
@Html.AntiForgeryToken()
   @Html.HiddenFor(x=>x.Id)
 <fieldset>
 <div class="form-group form-group-sm">
      <div class="row">

        <!--案件号-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.CaseId)</span> </label>
			@Html.EditorFor(x => x.CaseId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.CaseId) } })
      
         </div>

        <!--描述-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Description) </label>
			@Html.EditorFor(x => x.Description, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Description) } })
      
         </div>

        <!--文件名称-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.DocId) </label>
			@Html.EditorFor(x => x.DocId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.DocId) } })
      
         </div>

        <!--附件类型-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Type) </label>
			@Html.EditorFor(x => x.Type, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Type) } })
      
         </div>

        <!--保存路径-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Path)</span> </label>
			@Html.EditorFor(x => x.Path, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Path) } })
      
         </div>

        <!--文件类型-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Ext) </label>
			@Html.EditorFor(x => x.Ext, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Ext) } })
      
         </div>
	   </div>
    </div>
 <div class="form-group form-group-sm">
      <div class="row">

       <!--过期日-->
       <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.ExpireDate) </label>
            <div class="input-group">
			  @Html.EditorFor(x => x.ExpireDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.ExpireDate ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>
	    
   </div>
  </div>
</fieldset>
</form>
<!-- end attachment form  -->
</div>

<!-- end master section -->
<!--========================================================================================-->

