﻿@model WebApp.Models.TempCaseId
<!-- begin master section -->
<div class="row">
    <div class="col col-lg-12 col-md-12">
<!--begin tempcaseid form  -->
<form id="tempcaseid_form" class="smart-form" method="post" novalidate >
@Html.AntiForgeryToken()
  <input type="hidden" id="@Html.IdFor(model => model.Id)" 
                       name="@Html.NameFor(model => model.Id)" 
                       value="@Html.ValueFor(model => model.Id)" />
 <fieldset>
     <div class="row">
			              <!--档案编号-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.CaseId) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.CaseId)
            </label>
            </section>
 		 
	    
			              <!--案件类型-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.Category) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Category)
            </label>
            </section>
 		 
	   </div>
	    
     <div class="row">
			              <!--字号-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.SerialNumber) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.SerialNumber)
            </label>
            </section>
 		 
	    
			  			<!--标记-->
            <section class="col col-6">
            <label class="label"><span class="required">@Html.DisplayNameFor(model => model.Flag)</span> </label>
            <label class="label">
            @Html.DisplayFor(model => model.Flag)
			    </label>
            </section>
		 
	   </div>
	    
     <div class="row">
			              <!--Year-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.Year) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Year)
            </label>
            </section>
 		 
	    
			  			<!--Expires-->
            <section class="col col-6">
            <label class="label"><span class="required">@Html.DisplayNameFor(model => model.Expires)</span> </label>
            <label class="label">
            @Html.DisplayFor(model => model.Expires)
			    </label>
            </section>
		 
	   </div>
	    
	    
</fieldset>
</form>
<!-- end tempcaseid form  -->
</div>
</div>
<!-- end master section -->
<!--========================================================================================-->


