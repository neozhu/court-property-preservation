﻿@model WebApp.Models.NodeConfig
<!-- begin master section -->
<div  class="main-form">
<!--begin nodeconfig form  -->
<form id="nodeconfig_form" method="post" novalidate="novalidate" >
@Html.AntiForgeryToken()
   @Html.HiddenFor(x=>x.Id)
 <fieldset>
 <div class="form-group form-group-sm">
      <div class="row">

        <!--节点状态-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Node)</span> </label>
			@Html.EditorFor(x => x.Node, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Node) } })
      
         </div>

        <!--描述-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Description) </label>
			@Html.EditorFor(x => x.Description, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Description) } })
      
         </div>

		<!--限期(天)-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label"><span class="required">@Html.DisplayNameFor(model => model.Expires)</span> </label>
            @Html.EditorFor(x => x.Expires, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Expires) } })

        </div>

        <!--授权角色-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Roles) </label>
			@Html.EditorFor(x => x.Roles, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Roles) } })
      
         </div>

        <!--授权用户-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.Users) </label>
			@Html.EditorFor(x => x.Users, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Users) } })
      
         </div>

        <!--下个节点-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="control-label">@Html.DisplayNameFor(model => model.NextNode) </label>
			@Html.EditorFor(x => x.NextNode, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.NextNode) } })
      
         </div>
	   </div>
    </div>
	    
</fieldset>
</form>
<!-- end nodeconfig form  -->
</div>

<!-- end master section -->
<!--========================================================================================-->

