@model WebApp.Models.LegalCase
@{
  ViewBag.Title = "案件审批";
}
@section styles{
  <link href="~/Scripts/plugin/filepond/filepond.min.css" rel="stylesheet" />
}
<!-- MAIN CONTENT -->
<div id="content">
  <!-- quick navigation bar -->
  <div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-4">
      <h1 class="page-title txt-color-blueDark">
        <i class="fa fa-table fa-fw "></i>
        案件管理
        <span>
          >
          案件审批
        </span>
      </h1>
    </div>
    <div class="col-xs-12 col-sm-5 col-md-5 col-lg-8">

    </div>
  </div>
  <!-- end quick navigation bar -->
  <!-- widget grid -->
  <section id="widget-grid" class="">
    <!-- row -->
    <div class="row">
      <!-- NEW WIDGET START -->
      <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        <!-- Widget ID (each widget will need unique ID)-->
        <div class="jarviswidget" id="wid-id-0" data-widget-editbutton="false" data-widget-deletebutton="false">
          <!-- widget options:
          usage: <div class="jarviswidget" id="wid-id-0" data-widget-editbutton="false">
          data-widget-colorbutton="false"
          data-widget-editbutton="false"
          data-widget-togglebutton="false"
          data-widget-deletebutton="false"
          data-widget-fullscreenbutton="false"
          data-widget-custombutton="false"
          data-widget-collapsed="true"
          data-widget-sortable="false"
          -->
          <header>
            <span class="widget-icon"> <i class="fa fa-table"></i> </span>
            <h2>案件审批</h2>
          </header>

          <!-- widget div-->
          <div>
            <!-- widget edit box -->
            <div class="jarviswidget-editbox">
              <!-- This area used as dropdown edit box -->
            </div>
            <!-- end widget edit box -->
            <!-- widget content -->
            <div class="widget-body no-padding">
              <div class="sk-spinner sk-spinner-wave">
                <div class="sk-rect1"></div>
                <div class="sk-rect2"></div>
                <div class="sk-rect3"></div>
                <div class="sk-rect4"></div>
                <div class="sk-rect5"></div>
              </div>
              <div class="widget-body-toolbar">
                <div class="row">
                  <div class="col-sm-8  ">
                    <!-- 开启授权控制请参考 @@if (Html.IsAuthorize("Create") -->
                    <div class="btn-group btn-group-sm">
                      <button onclick="doexecution2()" class="btn btn-default btn-primary" data-rel="tooltip" data-placement="bottom" title="审批确认"> <i class="fa fa-check-square-o"></i> 审批确认 </button>
                    </div>

                    <div class="btn-group btn-group-sm">
                      <button onclick="reload()" class="btn btn-default" data-rel="tooltip" data-placement="bottom" title="@Html.L("Refresh")"> <i class="fa fa-refresh"></i> @Html.L("Refresh") </button>
                    </div>


                  </div>
                  <div class="col-sm-4 text-align-right visible-lg-inline-block">
                    <div class="btn-group btn-group-sm">
                      <button onclick="window.history.back()" class="btn btn-sm btn-success" data-rel="tooltip" data-placement="bottom" title="@Html.L("GoBack")"> <i class="fa fa-chevron-left"></i> @Html.L("GoBack") </button>
                    </div>
                  </div>
                </div>

              </div>
              <div class="alert alert-warning no-margin fade in">
                <button class="close" data-dismiss="alert">
                  ×
                </button>
                <i class="fa-fw fa fa-info"></i>
                注意事项:
              </div>
              <!--begin datagrid-content -->
              <div class="table-responsive">
                <table id="legalcases_datagrid">
                </table>
              </div>
              <!--end datagrid-content -->
            </div>
            <!-- end widget content -->
          </div>
          <!-- end widget div -->
        </div>
        <!-- end widget -->
      </article>
      <!-- WIDGET END -->
    </div>
    <!-- end row -->
  </section>
  <!-- end widget grid -->
  <!-- detail popup window -->
  @{ Html.RenderPartial("_PopupDetailFormView3", new WebApp.Models.LegalCase()); }
  <!-- end detail popup window -->
  @{ Html.RenderPartial("_PopupPrintView"); }
</div>
<!-- END MAIN CONTENT -->

@section Scripts {
  <script src="@Fingerprint.Tag("/Scripts/smartadmin.easyui.min.js")"></script>
  <script src="@Fingerprint.Tag("/Scripts/easyui/plugins/columns-reset.js")"></script>
  <script src="@Fingerprint.Tag("/Scripts/jquery.easyui.component.js")"></script>
  <script src="@Fingerprint.Tag("/Scripts/jquery.extend.formatter.js")"></script>
  @Html.LangScriptTag("/Scripts/easyui/locale/easyui-lang-zh_CN.js")
  <script src="~/Scripts/plugin/printthis/printThis.js"></script>
  <script src="~/Scripts/plugin/filepond/filepond.min.js"></script>
  <script src="~/Scripts/plugin/filepond/plugin/filepond-plugin-file-validate-type.min.js"></script>
  <script src="~/Scripts/plugin/filepond/plugin/filepond-plugin-file-validate-size.min.js"></script>
  <script type="text/javascript">
      //是否强制从后台取值
      const REQUIRBACKEND = false;
      //是否开启行内编辑
      const EDITINLINE = false;
      var legalcase = {};
    function printview(v, index) {
      legalcase = $dg.datagrid('getRows')[index];
      openprintviewwindow(legalcase,true);
    }
       var editIndex = undefined;
       //重新加载数据
       function reload() {
         $dg.datagrid('uncheckAll');
         $dg.datagrid('reload');
       }
  function doexecution2() {
    const selected = $dg.datagrid('getChecked').filter(item => item.Status == '审批')
      .map(item => {
        return item.Id;

      });
    if (selected.length > 0) {
      $.post('/LegalCases/ManagerTaskALL', { id: selected })
        .done(response => {
          if (response.success) {
            toastr.error(`成功完成[${selected.length}]行记录`);
            reload();
          } else {
            $.messager.alert('错误', response.err, 'error');
          }
        })
        .fail((jqXHR, textStatus, errorThrown) => {
          $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
        });
    } else {
      $.messager.alert('提示', '请先选择【审批】案件!', 'question');
    }
  }

    //弹出明细信息
    async function showdetailswindow(id,index) {
        const legalcase = $dg.datagrid('getRows')[index];
        if (REQUIRBACKEND) {
           legalcase = await $.get('/LegalCases/GetItem/' + id);
        }
        openlegalcasedetailwindow(legalcase,'Modified');
    }

    //初始化定义datagrid
    var $dg = $('#legalcases_datagrid');
  $(() => {
    //定义datagrid结构
    $dg.datagrid({
      rownumbers: true,
      checkOnSelect: false,
      selectOnCheck: false,
      idField: 'Id',
      sortName: 'Id',
      sortOrder: 'desc',
      remoteFilter: true,
      singleSelect: false,
      url: '/LegalCases/GetStep6Data',
      method: 'get',
      pagination: true,
      clientPaging: false,
      striped: true,
      pageList: [10, 20, 50, 100, 500],
      onHeaderContextMenu: function (e, field) {
        e.preventDefault();
        $(this).datagrid('columnMenu').menu('show', {
          left: e.pageX,
          top: e.pageY
        });
      },
      onBeforeLoad: function () {
        //datagrid resize when jarvisWidgets resized.
        const that = $(this);
        $(window).on("resize.jarvisWidgets", () => {
          that.datagrid('resize');
        })
      },
      onLoadSuccess: function (data) {
        editIndex = undefined;
        $('[data-toggle="tooltip"]').tooltip();
      },
      onCheck: function () {
        $("button[name*='deletebutton']").prop('disabled', false);
      },
      onUncheck: function () {
        const checked = $(this).datagrid('getChecked').length > 0;
        $("button[name*='deletebutton']").prop('disabled', !checked);
      },
      onSelect: function (index, row) {
        legalcase = row;
      },
      onBeginEdit: function (index, row) {
        //const editors = $(this).datagrid('getEditors', index);

      },
      onEndEdit: function (index, row) {

      },
      onBeforeEdit: function (index, row) {
        editIndex = index;
        row.editing = true;
        $("button[name*='deletebutton']").prop('disabled', false);
        $("button[name*='cancelbutton']").prop('disabled', false);
        $("button[name*='savebutton']").prop('disabled', false);
        $(this).datagrid('refreshRow', index);
      },
      onAfterEdit: function (index, row) {
        row.editing = false;
        editIndex = undefined;
        $(this).datagrid('refreshRow', index);
      },
      onCancelEdit: function (index, row) {
        row.editing = false;
        editIndex = undefined;
        $("button[name*='deletebutton']").prop('disabled', true);
        $("button[name*='savebutton']").prop('disabled', true);
        $("button[name*='cancelbutton']").prop('disabled', true);
        $(this).datagrid('refreshRow', index);
      },
      frozenColumns: [[
        /*开启CheckBox选择功能*/
        { field: 'ck', checkbox: true },
        {
          field: 'action',
          title: '@Html.L("Command")',
          width: 85,
          sortable: false,
          resizable: true,
          formatter: function showdetailsformatter(value, row, index) {
            return `<div class="btn-group">\
                         <button onclick = "showdetailswindow('${row.Id}',  ${index})" class="btn btn-default btn-xs" data-toggle="tooltip" data-placement="right" title="审批确认" ><i class="fa  fa-check-square-o"></i> </button>\
                          <button onclick="printview('${row.Id}',${index})" class="btn btn-default btn-xs" data-toggle="tooltip" data-placement="right" title="打印预览申请表" ><i class="fa fa-print"></i> </button>\
                        <button onclick = "goback('${row.Id}',${index})" class="btn btn-default btn-xs" data-toggle="tooltip" data-placement="right" title="退回" ><i class="fa fa-undo"></i> </button>\
                      </div>`;
          }
        }
      ]],
     columns: [[
         {     /*限期*/
          field: 'Expires',
          title: '<span class="required">@Html.DisplayNameFor(model => model.Expires)</span>',
          width: 100,
          align: 'right',
          hidden: false,
          editor: {
            type: 'numberspinner',
            options: {
              prompt: '@Html.DisplayNameFor(model => model.Expires)',
              required: true,

            }
          },
          formatter: function (v, r, i) {
            return remdays(r.PreCloseDate, v).text;
          },
          styler: function (v, r, index) {

            if (remdays(r.PreCloseDate, v).days < 0) {
              return 'background-color:#D84315;color:#fff;';
              // the function can return predefined css class and inline style
              // return {class:'c1',style:'color:red'}
            } else {
              return 'background-color:#A5D6A7;color:#000;';
            }
          },
          resizable: true
        },
        {    /*状态*/
          field: 'Status',
          title: '<span class="required">@Html.DisplayNameFor(model => model.Status)</span>',
          width: 80,
          align: 'right',
          hidden: false,
          editor: {
            /*需要在键值对中维护status枚举值并生成JavaScript才能使用*/
            type: 'statuseditor',
            options: {
              prompt: '@Html.DisplayNameFor(model => model.Status)',
              required: true
            }
          },
          formatter: statusformatter
        },
        {    /*档案编号*/
          field: 'CaseId',
          title: '<span class="required">@Html.DisplayNameFor(model => model.CaseId)</span>',
          width: 170,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.CaseId)', required: true, validType: 'length[0,50]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*申请保全人*/
          field: 'Accuser',
          title: '@Html.DisplayNameFor(model => model.Accuser)',
          width: 160,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Accuser)', required: false, validType: 'length[0,250]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*被保全人*/
          field: 'Defendant',
          title: '@Html.DisplayNameFor(model => model.Defendant)',
          width: 160,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Defendant)', required: false, validType: 'length[0,250]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*案件原由*/
          field: 'Cause',
          title: '@Html.DisplayNameFor(model => model.Cause)',
          width: 200,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Cause)', required: false, validType: 'length[0,50]' }
          },
          sortable: true,
          resizable: true
        },
         {    /*执行依据文号*/
          field: 'BasedOn',
          title: '@Html.DisplayNameFor(model => model.BasedOn)',
          width: 210,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.BasedOn)', required: false, validType: 'length[0,100]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*承办人*/
          field: 'ToUser',
          title: '@Html.DisplayNameFor(model => model.ToUser)',
          width: 90,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.ToUser)', required: false, validType: 'length[0,20]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*书记员*/
          field: 'Recorder',
          title: '@Html.DisplayNameFor(model => model.Recorder)',
          width: 90,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Recorder)', required: false, validType: 'length[0,20]' }
          },
          sortable: true,
          resizable: true
        },
         {    /*原案（执行）案号*/
          field: 'OriginCaseId',
          title: '@Html.DisplayNameFor(model => model.OriginCaseId)',
          width: 200,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.OriginCaseId)', required: false, validType: 'length[0,50]' }
          },
          sortable: true,
          resizable: true
        },
         {   /*结案日期*/
          field: 'ClosedDate',
          title: '@Html.DisplayNameFor(model => model.ClosedDate)',
          width: 100,
          align: 'right',
          hidden: false,
          editor: {
            type: 'datebox',
            options: { prompt: '@Html.DisplayNameFor(model => model.ClosedDate)', required: false }
          },
          formatter: dateformatter,
          sortable: true,
          resizable: true
        },
        {   /*立案日期*/
          field: 'RegisterDate',
          title: '<span class="required">@Html.DisplayNameFor(model => model.RegisterDate)</span>',
          width: 100,
          align: 'right',
          hidden: false,
          editor: {
            type: 'datebox',
            options: { prompt: '@Html.DisplayNameFor(model => model.RegisterDate)', required: true }
          },
          formatter: dateformatter,
          sortable: true,
          resizable: true
        },
        {    /*承办部门*/
          field: 'ToDepartment',
          title: '@Html.DisplayNameFor(model => model.ToDepartment)',
          width: 120,
          hidden: true,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.ToDepartment)', required: false, validType: 'length[0,20]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*填表人*/
          field: 'Proposer',
          title: '@Html.DisplayNameFor(model => model.Proposer)',
          width: 100,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Proposer)', required: false, validType: 'length[0,20]' }
          },
          sortable: true,
          resizable: true
        },
        {    /*备注*/
          field: 'Comment',
          title: '@Html.DisplayNameFor(model => model.Comment)',
          width: 200,
          hidden: false,
          editor: {
            type: 'textbox',
            options: { prompt: '@Html.DisplayNameFor(model => model.Comment)', required: false, validType: 'length[0,50]' }
          },
          sortable: true,
          resizable: true
        }
      ]]
    }).datagrid('columnMoving')
      .datagrid('resetColumns');

    $dg.datagrid('enableFilter', [
      /*需要在键值队维护好status枚举值*/
      {  /*状态*/
        field: 'Status',
        type: 'status6filter',
        options: {

        }
      },
      {  /*状态*/
        field: 'Category',
        type: 'categoryfilter',
        options: {

        }
      },

      {   /*限期*/
        field: 'Expires',
        type: 'textbox',
        options: {
          readonly: true
        }
      },
      {   /*申请执行标的*/
        field: 'PreUnderlyingAsset',
        type: 'numberbox',
        op: ['equal', 'notequal', 'less', 'lessorequal', 'greater', 'greaterorequal']
      },
      {   /*结案标的*/
        field: 'UnderlyingAsset',
        type: 'numberbox',
        op: ['equal', 'notequal', 'less', 'lessorequal', 'greater', 'greaterorequal']
      },
      {   /*应收执行费*/
        field: 'Receivable',
        type: 'numberbox',
        op: ['equal', 'notequal', 'less', 'lessorequal', 'greater', 'greaterorequal']
      },
      {   /*已收执行费*/
        field: 'Received',
        type: 'numberbox',
        op: ['equal', 'notequal', 'less', 'lessorequal', 'greater', 'greaterorequal']
      },
      {     /*收案日期*/
        field: 'ReceiveDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*立案日期*/
        field: 'RegisterDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*分案时间*/
        field: 'AllocateDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*应结案日期*/
        field: 'PreCloseDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*结案日期*/
        field: 'ClosedDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*填表日期*/
        field: 'FilingDate',
        type: 'dateRange',
        options: {
        }
      },
      {     /*节点开始时间*/
        field: 'ToDoDate',
        type: 'dateRange',
        options: {
        }
      },
    ]);

    //计算剩余天数
    function remdays(date1, days) {
      var date2 = moment().startOf('day');
      var date1 = moment(date1);
      // The number of milliseconds in one day
      const ONE_DAY = 1000 * 60 * 60 * 24;

      // Calculate the difference in milliseconds
      const differenceMs = date1 - date2;
      if (differenceMs >= 0) {
        // Convert back to days and return
        return { days: Math.round(differenceMs / ONE_DAY), text: `剩余${Math.round(differenceMs / ONE_DAY)}天 ` };
      } else {
        return { days: Math.round(differenceMs / ONE_DAY), text: `超过${Math.round(differenceMs / ONE_DAY)}天 ` };
      }

    }

  });

  </script>



}


