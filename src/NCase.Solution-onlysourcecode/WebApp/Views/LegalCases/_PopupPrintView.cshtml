<!-- 弹出窗体form表单 -->
<div id="printviewwindow" hidden="hidden" class="easyui-window"
     title="案件立案审批表预览"
     data-options="modal:true,
                    closed:true,
                    minimizable:false,
                    collapsible:false,
                    maximized:false,
                    iconCls:'icon-more',
                    footer:'#windowfooter',
                    closeDuration:200,
                    closeAnimation:'slide',
                    openDuration:300,
                    openAnimation:'slide',
                    onBeforeClose:function(){

                    },
                    onOpen:function(){
                       $(this).window('vcenter');
                       $(this).window('hcenter');
                    },
                    onRestore:function(){
                    },
                    onMaximize:function(){
                    }
                    " style="width:820px;height:650px">
  <!-- begin toolbar -->
  <div class="window-body-toolbar">
    <div class="row">
      <div class="col-sm-8">
        <div class="btn-group btn-group-sm">
          <button name="print" onclick="printdiv()" class="btn btn-default btn-success">
            <i class="fa fa-print"></i> 打印
          </button>
        </div>


      </div>
      <div class="col-sm-4 text-align-right">
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn   btn-success" onclick="closeprintviewwindow()">
            <i class="fa fa-chevron-left"></i>
            @Html.L("Close")
          </button>
        </div>
      </div>
    </div>
  </div>
  <!-- end toolbar -->
  <!-- begin window body -->
  <div class="widget-body padding-10">
    <div data-size="A4" style="max-width:960px" id="printa4">
      <style>
        .table-bordered1 > thead > tr > th, .table-bordered1 > tbody > tr > th, .table-bordered1 > tfoot > tr > th, .table-bordered1 > thead > tr > td, .table-bordered1 > tbody > tr > td, .table-bordered1 > tfoot > tr > td {
          border: 2px solid #000;
        }
      </style>
      <div class="text-align-center">
        <h1 style="font-size:200%" id="title">执保案件立案审批表</h1>
      </div>
      <span class="float-right" id="sp_FromDepartment">承办庭：执行局</span>
      <table class="table table-bordered1" style="border:2px solid black">
        <tbody>
          <tr>
            <td width="13%">收案日期</td>
            <td width="37%" id="td_ReceiveDate"></td>

            <td width="14%">案号</td>
            <td width="36%" id="td_CaseId">（2020）粤0605保变15号</td>
          </tr>
          <tr>
            <td height="170px">申请<br>保全人</td>
            <td id="td_Accuser"></td>
            <td>地址</td>
            <td id="td_AccuserAddress"></td>

          </tr>
          <tr>
            <td height="170px">被保全人</td>
            <td id="td_Defendant"></td>
            <td>地址</td>
            <td id="td_DefendantAddress"></td>

          </tr>
          <tr>
            <td>申请执行<br>依据</td>
            <td id="td_BasedOn"></td>
            <td rowspan="2">案由</td>
            <td rowspan="2" id="td_Cause"></td>

          </tr>
          <tr>
            <td>原案(执行)<br>案号</td>
            <td id="td_OriginCaseId"></td>


          </tr>
          <tr>
            <td rowspan="2">
              执	行<br>
              标	的
            </td>
            <td rowspan="2" id="td_PreUnderlyingAsset" style="text-align:right;vertical-align:inherit"></td>
            <td>应收执行费</td>
            <td></td>

          </tr>
          <tr>

            <td height="40px">已收执行费</td>
            <td></td>

          </tr>
          <tr>
            <td height="50px">承办人<br>意见</td>
            <td colspan="3"></td>
          </tr>
          <tr>
            <td height="50px">立案组<br>意见</td>
            <td colspan="3"></td>
          </tr>
          <tr>
            <td>
              院	长<br>批	示
            </td>
            <td colspan="3"></td>
          </tr>
          <tr>
            <td>
              备注<br><br>
            </td>
            <td colspan="3" id="td_Comment"></td>
          </tr>
          <tr>
            <td>
              填表人
            </td>
            <td id="td_Proposer"></td>
            <td>
              填表日期
            </td>
            <td id="td_FilingDate"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
<!--end window body -->

<div id="windowfooter" style="padding:5px;">&nbsp;</div>
<!-- 弹出窗体form表单 -->
<!-- 弹出编辑对话框 -->
<!--begin popup detailview javascript block -->
<script type="text/javascript">
  var selectedIds = null;
  function openprintviewwindow(data,disabled) {
    //$("button[name*='print']").prop('disabled', disabled);
    $('#printviewwindow').window('open');
    //$('#title').html(`${data.Category}案件立案审批表`)
    $('#sp_FromDepartment').html(`承办庭：${data.FromDepartment||''}`)
    $('#td_ReceiveDate').html(`${moment(data.ReceiveDate).format('YYYY年MM月DD日')}`)
    $('#td_CaseId').html(`${data.CaseId||''}`)
    $('#td_Accuser').html(`${data.Accuser||''}`)
    $('#td_AccuserAddress').html(`${data.AccuserAddress||''}`)
    $('#td_DefendantAddress').html(`${data.DefendantAddress||''}`)
    $('#td_Defendant').html(`${data.Defendant||''}`)
    $('#td_BasedOn').html(`${data.BasedOn||''}`)
    $('#td_Cause').html(`${data.Cause||''}`)
    $('#td_PreUnderlyingAsset').html(`${data.PreUnderlyingAsset} 元`)
    $('#td_Proposer').html(`${data.Proposer||''}`)
    $('#td_OriginCaseId').html(`${data.OriginCaseId||''}`)
    $('#td_Comment').html(`${data.Comment ||''}`)
    $('#td_FilingDate').html(`${moment(data.FilingDate).format('YYYY年MM月DD日')}`)

  }
  function printdiv() {
    $('#printa4').printThis({
      importCSS: true,
      removeScripts: false,       // remove script tags from print content
      copyTagClasses: false,
      header: null,               // prefix to html
      footer: null,
      header: ''
    });
  }
  function closeprintviewwindow() {
    $('#printviewwindow').window("close");
  }
</script>

