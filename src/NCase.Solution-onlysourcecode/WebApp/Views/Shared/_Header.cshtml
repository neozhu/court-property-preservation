    <!-- HEADER -->
<header id="header">
  <div id="logo-group">

    <!-- PLACE YOUR LOGO HERE -->
    <a href="/">
      <span id="logo" style="margin-top:2px">
      <img style="width:260px" src="~/Content/img/logo.png" alt="SmartAdmin">
      </span>
      </a>
</div>
    <section id="top-right">
        @if (@Model is HelperResult)
        {
            @Model
        }
        else
        {
            <div class="pull-right">
                @Html.Partial("_TopRight")
            </div>
        }
    </section>
</header>
<!-- END HEADER -->