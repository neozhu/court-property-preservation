﻿@model WebApp.Models.Court
<!-- 弹出窗体form表单 -->
 <div id="courtdetailwindow" hidden="hidden" class="easyui-window" 
      title="明细数据" 
      data-options="modal:true,
                    closed:true,
                    minimizable:false,
                    collapsible:false,
                    maximized:false,
                    iconCls:'icon-more',
                    footer:'#windowfooter',
                    closeDuration:200,
                    closeAnimation:'slide',
                    openDuration:300,
                    openAnimation:'slide',
                    onBeforeClose:function(){
                      var that = $(this);
                      if(courthasmodified()){
                        $.messager.confirm('确认','你确定要放弃保存修改的记录?',function(r){
                        if (r){
                          var opts = that.panel('options');
                          var onBeforeClose = opts.onBeforeClose;
                          opts.onBeforeClose = function(){};
                          that.panel('close');
                          opts.onBeforeClose = onBeforeClose;
                          hook = false;
                        }
                        });
                        return false;
                      }
                    },
                    onOpen:function(){
                       $(this).window('vcenter');
                       $(this).window('hcenter');
                    },
                    onRestore:function(){
                    },
                    onMaximize:function(){
                    }
                    " style="width:1020px;height:230px">
    <!-- begin toolbar -->
    <div class="window-body-toolbar">
        <div class="row">
            <div class="col-sm-8">
                <div class="btn-group btn-group-sm">
                       <button name="saveitembutton" onclick="savecourtitem()" class="btn btn-default"> 
                          <i class="fa fa-floppy-o"></i> @Html.L("Save") 
                       </button>
                </div>
                <div class="btn-group btn-group-sm" id="deleteitem-btn-group">
                  <button onclick="deletecourtitem()" class="btn btn-danger">
                    <i class="fa fa-trash-o"></i> @Html.L("Delete")
                  </button>
                </div>
                <div class="btn-group btn-group-sm" style="display:none">
                    <button onclick="todo()" class="btn btn-default">
                        <i class="fa fa-print"></i> ToDo
                    </button>
                </div>
            </div>
            <div class="col-sm-4 text-align-right">
              <div class="btn-group btn-group-sm">
                <button type="button" class="btn   btn-success" onclick="closecourtdetailwindow()">
                    <i class="fa fa-chevron-left"></i>
                    @Html.L("Close")
                </button>
              </div>
            </div>
        </div>
    </div>
    <!-- end toolbar -->
    <!-- begin window body -->
    <div class="widget-body">
           <form id="court_form" 
              class="easyui-form form-horizontal padding-10" 
              method="post" 
              data-options="novalidate:true,
                            onChange: function(target){
                              hook = true;
                              $('button[name*=\'saveitembutton\']').prop('disabled', false);
                             },
                             onLoadSuccess:function(data){
                               hook = false;
                               $('button[name*=\'saveitembutton\']').prop('disabled', true);
                             }">
  @Html.AntiForgeryToken()
   <!--Primary Key-->
  @Html.HiddenFor(model=>model.Id)
   <fieldset>
<!-- begin row -->
   <!--法庭名称-->
  <div class="form-group  col-md-6">
        <label class="col-md-2 control-label"><span class="required">@Html.DisplayNameFor(model => model.Name)</span></label>
		<div class="col-md-10">  
			<input id="@Html.IdFor(model => model.Name)" 
				   name="@Html.NameFor(model => model.Name)" 
				   value="@Html.ValueFor(model => model.Name)"
				   tabindex="0" required
				   class="easyui-textbox" 
                   style="width:100%"
				   type="text" 
				   data-options="prompt:'@Html.DisplayNameFor(model => model.Name)',
								 required:true, 
                                 validType: 'length[0,50]'
                                 " />
       </div>
  </div>
				      <!--所在地-->
  <div class="form-group  col-md-6">
        <label class="col-md-2 control-label">@Html.DisplayNameFor(model => model.Zone)</label>
		<div class="col-md-10">  
			<input id="@Html.IdFor(model => model.Zone)" 
				   name="@Html.NameFor(model => model.Zone)" 
				   value="@Html.ValueFor(model => model.Zone)"
				   tabindex="1" 
				   class="easyui-textbox" 
                   style="width:100%"
				   type="text" 
				   data-options="prompt:'@Html.DisplayNameFor(model => model.Zone)',
								 required:false, 
                                 validType: 'length[0,50]'
                                 " />
       </div>
  </div>
				          <!--end row-->
	   <!-- begin row -->
   <!--地址-->
  <div class="form-group  col-md-6">
        <label class="col-md-2 control-label">@Html.DisplayNameFor(model => model.Address)</label>
		<div class="col-md-10">  
			<input id="@Html.IdFor(model => model.Address)" 
				   name="@Html.NameFor(model => model.Address)" 
				   value="@Html.ValueFor(model => model.Address)"
				   tabindex="2" 
				   class="easyui-textbox" 
                   style="width:100%"
				   type="text" 
				   data-options="prompt:'@Html.DisplayNameFor(model => model.Address)',
								 required:false, 
                                 validType: 'length[0,150]'
                                 " />
       </div>
  </div>
				      <!--联系方式-->
  <div class="form-group  col-md-6">
        <label class="col-md-2 control-label">@Html.DisplayNameFor(model => model.Contect)</label>
		<div class="col-md-10">  
			<input id="@Html.IdFor(model => model.Contect)" 
				   name="@Html.NameFor(model => model.Contect)" 
				   value="@Html.ValueFor(model => model.Contect)"
				   tabindex="3" 
				   class="easyui-textbox" 
                   style="width:100%"
				   type="text" 
				   data-options="prompt:'@Html.DisplayNameFor(model => model.Contect)',
								 required:false, 
                                 validType: 'length[0,150]'
                                 " />
       </div>
  </div>
				          <!--end row-->
	   <!-- begin row -->
    <!--法院ID-->
    <div class="form-group  col-md-6">
        <label class="col-md-2 control-label"><span class="required">@Html.DisplayNameFor(model => model.CompanyId)</span></label>
		<div class="col-md-10">   	
            <input id="@Html.IdFor(model => model.CompanyId)"
			       name="@Html.NameFor(model => model.CompanyId)"
				   value="@Html.ValueFor(model => model.CompanyId)"
                   tabindex="4" required
              	   class="easyui-combobox"      
                   style="width:100%"
                   data-options="prompt:'@Html.DisplayNameFor(model => model.CompanyId)' ,
						required:true ,
						valueField: 'Id',
						textField:  'Name' ,
                        validateOnCreate:false,
                        validateOnBlur:true,
                        validType:'combocheck[\'#CompanyId\',\'请选择法院ID\']',
						url: '/Courts/GetCompanies' ,
						onSelect: function(item){
						  //console.log(item);
				        }">
       </div>
    </div>
	   	             <!--end row-->
	      </fieldset>
   </form>

<!--end form表单界面-->
<!--========================================================================================-->
     </div>
    <!--end window body -->
</div>
<div id="windowfooter" style="padding:5px;">&nbsp;</div>
<!-- 弹出窗体form表单 -->
<!-- 弹出编辑对话框 -->

<!--begin popup detailview javascript block -->
<script type="text/javascript">
    //判断新增编辑状态
    var MODELSTATE = 'Added';
    var courtid = null;
    function opencourtdetailwindow(data,state) {
         MODELSTATE = state;
         initcourtdetailview();
         courtid = (data.Id || 0);
         $('#courtdetailwindow').window('open');
         $('#court_form').form('reset');
         $('#court_form').form('load', data);
             }
  //删除当前记录
  function deletecourtitem() {
    $.messager.confirm('确认', '你确定要删除该记录?', result => {
      if (result) {
        const url = `/Courts/Delete/${courtid}`;
        $.get(url).done(res => {
          if (res.success) {
            toastr.success("删除成功");
            $dg.datagrid('reload');
            $('#courtdetailwindow').window('close');
          } else {
            $.messager.alert('错误', res.err, 'error');
          }
        });
      }
    });
  }
    //async 保存数据
    async function savecourtitem() { 
      const $courtform = $('#court_form');
      if ($courtform.form('enableValidation').form('validate')) {
            let court = $courtform.serializeJSON();
            let url = '/Courts/Edit';
            //判断是新增或是修改方法
            if (MODELSTATE === 'Added') {
                url = '/Courts/Create';
            }
            var token = $('input[name="__RequestVerificationToken"]', $courtform).val();
            $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval:200});
            $.ajax({
                    type: "POST",
                    url: url,
                    data: {
                        __RequestVerificationToken: token,
                        court:court
                    },
                    dataType: 'json',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8'
                })
                .done(response => {
                    $.messager.progress('close');
                    if (response.success) {
                        hook = false;
                        $courtform.form('disableValidation');
                        $dg.datagrid('reload');
                        $('#courtdetailwindow').window("close");
                        toastr.success("保存成功");  
                    } else {
                        $.messager.alert("错误",   response.err, "error");
                    }
                    })
                .fail((jqXHR, textStatus, errorThrown) => {
                       $.messager.progress('close');
                       $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
                    });
        }
    }
    //关闭窗口
    function closecourtdetailwindow() {
        $('#courtdetailwindow').window('close');
    }
    //todo
    function todo() {
         console.log('todo.....');
    }
     //判断是否有没有保存的记录
     function courthasmodified() {
            return hook;

     }


function initcourtdetailview() {
  //判断是否显示功能按钮
  if (MODELSTATE === 'Added') {
    $('#deleteitem-btn-group').hide();
  } else {
    $('#deleteitem-btn-group').show();
  }
 
//回车光标移动到下个输入控件
    //法院ID默认外键使用combobox,也可以使用combogrid
	$('#CompanyId').combobox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
}
</script>

