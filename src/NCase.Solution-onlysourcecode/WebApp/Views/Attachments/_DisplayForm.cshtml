﻿@model WebApp.Models.Attachment
<!-- begin master section -->
<div class="row">
    <div class="col col-lg-12 col-md-12">
<!--begin attachment form  -->
<form id="attachment_form" class="smart-form" method="post" novalidate >
@Html.AntiForgeryToken()
  <input type="hidden" id="@Html.IdFor(model => model.Id)" 
                       name="@Html.NameFor(model => model.Id)" 
                       value="@Html.ValueFor(model => model.Id)" />
 <fieldset>
     <div class="row">
			              <!--案件号-->
            <section class="col col-6">
            <label class="label"><span class="required">@Html.DisplayNameFor(model => model.CaseId)</span> </label>
            <label class="label">
			 @Html.DisplayFor(model => model.CaseId)
            </label>
            </section>
 		 
	    
			              <!--描述-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.Description) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Description)
            </label>
            </section>
 		 
	   </div>
	    
     <div class="row">
			              <!--文件名称-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.DocId) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.DocId)
            </label>
            </section>
 		 
	    
			              <!--附件类型-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.Type) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Type)
            </label>
            </section>
 		 
	   </div>
	    
     <div class="row">
			              <!--保存路径-->
            <section class="col col-6">
            <label class="label"><span class="required">@Html.DisplayNameFor(model => model.Path)</span> </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Path)
            </label>
            </section>
 		 
	    
			              <!--文件类型-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.Ext) </label>
            <label class="label">
			 @Html.DisplayFor(model => model.Ext)
            </label>
            </section>
 		 
	   </div>
	    
     <div class="row">
			              <!--过期日-->
            <section class="col col-6">
            <label class="label">@Html.DisplayNameFor(model => model.ExpireDate) </label>
            <label class="label">
            
			@Html.DisplayFor(model => model.ExpireDate)
			    </label>
            </section>
			  		 
	    
   </div>
	    
</fieldset>
</form>
<!-- end attachment form  -->
</div>
</div>
<!-- end master section -->
<!--========================================================================================-->


